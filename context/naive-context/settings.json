{
  "features": {
    "agent_sessions": {
      "enabled": true,
      "lookback_hours": 168,
      "max_entries": 50,
      "max_observations_per_session": 3,
      "providers": ["codex", "claude"],
      "include_codex_subagents": false,
      "include_non_edit_sessions": true
    },
    "browser_history": {
      "enabled": true,
      "lookback_hours": 72,
      "max_entries": 50,
      "browsers": ["chrome", "edge", "brave", "firefox"]
    }
  }
}
